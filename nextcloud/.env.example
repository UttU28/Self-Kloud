# Copy to .env and change every password before first deploy:
#   cp .env.example .env && nano .env

# --- Paths ---
# Local install (default):
NEXTCLOUD_DATA_PATH=/home/dedsec995/Desktop/selfHosted/nextcloud/data
NEXTCLOUD_DB_PATH=/home/dedsec995/Desktop/selfHosted/nextcloud/db

# Chitragupt disk (after: sudo ~/Desktop/selfHosted/chitragupt.sh migrate):
# NEXTCLOUD_DATA_PATH=/mnt/chitragupt/nextcloud/data
# NEXTCLOUD_DB_PATH=/mnt/chitragupt/nextcloud/db
# CHITRAGUPT_ROOT=/mnt/chitragupt
# CHITRAGUPT_UUID=6707d4b1-94cc-4a94-bbbd-eede82969001
# JELLYFIN_MEDIA_PATH=/mnt/chitragupt/jellyfin/media

# --- Public URL ---
NEXTCLOUD_DOMAIN=kloud.thatinsaneguy.com
NEXTCLOUD_PORT=9270

# --- First-time admin (used by deploy.sh occ install only — not passed to Docker) ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeMeToStrongPassword

# --- MariaDB ---
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
MYSQL_PASSWORD=changeMeToRandomDbPassword
MYSQL_ROOT_PASSWORD=changeMeToRandomRootPassword

# --- Image pin (optional) ---
# NEXTCLOUD_VERSION=latest

# --- Timezone ---
TZ=Asia/Kolkata
